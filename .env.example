# Copy to .env and fill in values. Never commit .env.

# --- Discord (required) ---
DISCORD_TOKEN=

# Orchestrator listens on this channel for new requests (channel snowflake).
DISCORD_ORCHESTRATOR_CHANNEL_ID=

# Optional: used in discord-check curl examples for /guilds/.../threads/active
# DISCORD_GUILD_ID=

# --- Jira Cloud REST API (orchestrator) ---
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
# Cloud ID: Admin → Jira → System → System info, or from Atlassian API.
JIRA_CLOUD_ID=
# Short project key, e.g. PROJ
JIRA_PROJECT_KEY=
# Human-facing issue links in Discord, no trailing slash, e.g. https://your-site.atlassian.net/browse
JIRA_BROWSE_BASE_URL=

# --- Langfuse ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- LLM (at least one for real planning / agent_act) ---
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=

# Legacy alias (optional if OPENROUTER_API_KEY is set)
# OpenRouter_Key=

# --- Optional: wanddy_planner.py local smoke test only ---
# PLANNER_SAMPLE_DISCORD_USER_ID=000000000000000000
# PLANNER_SAMPLE_DISCORD_THREAD_ID=000000000000000001

# --- Optional: other tooling (not read by wanddy_*.py) ---
# GIT_HUB_TOKEN=
# JIRA_URL=https://your-site.atlassian.net/
# DISCORD_APPLICATION_ID=
# DISCORD_PUBLIC_KEY=
